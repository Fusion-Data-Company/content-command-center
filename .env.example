# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenRouter API — powers all AI content generation
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# fal.ai — powers image generation (Studio, hero images, infographics)
FAL_KEY=your-fal-key-here

# Vercel Blob Storage — powers file uploads (images, assets)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# WordPress App Password Encryption Key — 32+ character random string
# Generate with: openssl rand -hex 32
WP_ENCRYPTION_KEY=your-random-encryption-key-here
